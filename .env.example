# API 服务地址
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_URL=http://127.0.0.1:8000
API_FORWARD_MAX_RETRIES=3
API_FORWARD_RETRY_DELAY_SECONDS=1
FAILED_EVENT_QUEUE_PATH=failed_events.jsonl

# Kafka 配置
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=ai-diagnostics
KAFKA_GROUP_ID=ai-diagnostic-group
KAFKA_AUTO_OFFSET_RESET=latest

# 会话存储
# 可选: memory / redis
SESSION_STORE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# AI 模型
# 配置后走真实 Gemini；不配置则走本地规则兜底
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash-lite
